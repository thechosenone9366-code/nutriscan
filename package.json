{
  "name": "nutriscan",
  "version": "1.0.0",
  "description": "NutriScan - Scanner alimentaire avec analyse nutritionnelle",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Web assets ready in www/'",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "cap:build:release": "cd android && ./gradlew assembleRelease",
    "setup": "npm install && npx cap add android && npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  },
  "keywords": ["food", "nutrition", "scanner", "capacitor", "android"],
  "author": "NutriScan",
  "license": "MIT"
}
