<?xml version="1.0" encoding="utf-8"?>
<!-- Remplacer android/app/src/main/res/values/styles.xml -->
<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">#00f5c4</item>
        <item name="colorPrimaryDark">#0a0a12</item>
        <item name="colorAccent">#00f5c4</item>
        <item name="android:windowBackground">#0a0a12</item>
    </style>

    <!-- Splash / Launch theme (no action bar, full screen) -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">#0a0a12</item>
        <item name="windowSplashScreenBackground">#0a0a12</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">#0a0a12</item>
        <item name="android:navigationBarColor">#0a0a12</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
